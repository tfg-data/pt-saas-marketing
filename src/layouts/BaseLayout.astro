---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { url } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'VB6・VB.NET・C#など、ソースコードがあれば対応。レガシー生産管理システムをAI支援でクラウドSaaSへ最短3ヶ月で移行。製造業向け160機能・15ドメイン対応。既存MySQLデータはそのまま。株式会社TFGデータ。',
  ogImage = '/images/og-default.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "PT-SaaS",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "製造業向けクラウド型生産管理SaaS。ソースコードがあればあらゆるレガシーシステムをAI支援で移行。",
  "offers": { "@type": "Offer", "priceCurrency": "JPY" },
  "provider": {
    "@type": "Organization",
    "name": "株式会社TFGデータ",
    "url": "https://tfgdata.jp",
    "email": "tfg-support@tfgdata.jp",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "宇治市",
      "addressRegion": "京都府",
      "addressCountry": "JP"
    }
  }
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={url('/images/tfglogo.png')} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="VB6移行,レガシーシステム移行,生産管理SaaS,製造業DX,PT-SaaS,TFGデータ" />
    <link rel="canonical" href={canonicalURL} />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="PT-SaaS | TFGデータ" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Google Fonts: Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD 構造化データ -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-white text-slate-800 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
