---
const links = [
  {
    heading: 'サービス',
    items: [
      { label: 'PT-SaaSとは', href: '/features/' },
      { label: 'レベル1（受注・出荷）', href: '/features/#level1' },
      { label: 'レベル2（購買・外注）', href: '/features/#level2' },
      { label: 'レベル3（生産計画）', href: '/features/#level3' },
    ],
  },
  {
    heading: '導入・料金',
    items: [
      { label: '料金プラン', href: '/pricing/' },
      { label: 'よくある質問', href: '/faq/' },
      { label: 'お問い合わせ', href: '/contact/' },
    ],
  },
  {
    heading: '会社情報',
    items: [
      { label: '会社のご案内', href: '/company/' },
    ],
  },
];
---

<footer class="bg-slate-900 text-slate-400">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- ブランド -->
      <div class="md:col-span-1">
        <img src="/images/tfglogo.png" alt="TFG DATA" class="h-10 w-auto brightness-0 invert opacity-80 mb-3" />
        <p class="text-sm leading-relaxed">
          中小製造業向けクラウド型<br />生産管理システム
        </p>
        <p class="mt-3 text-xs text-slate-500">
          お問い合わせ:<br />
          <a href="mailto:tfg-support@tfgdata.jp" class="hover:text-white transition-colors">
            tfg-support@tfgdata.jp
          </a>
        </p>
      </div>

      <!-- ナビゲーション -->
      {links.map((group) => (
        <div>
          <h3 class="text-sm font-semibold text-white mb-3">{group.heading}</h3>
          <ul class="space-y-2">
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm hover:text-white transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 pt-6 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-slate-500">
      <p>&copy; {new Date().getFullYear()} 株式会社 TFGデータ. All rights reserved.</p>
      <p>京都府宇治市木幡平尾28番地683号</p>
    </div>
  </div>
</footer>
