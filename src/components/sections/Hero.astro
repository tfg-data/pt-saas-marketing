---
import { url } from '../../lib/url';
---

<section class="bg-primary-900 text-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20 lg:py-24">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
      <!-- テキストコンテンツ -->
      <div class="flex-1 text-center lg:text-left animate-fade-in-up">
        <!-- バッジ -->
        <div class="inline-flex items-center gap-2 bg-primary-800/60 border border-primary-700 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          <span class="text-sm font-medium text-primary-200">製造業DX専門 — AI支援移行</span>
        </div>

        <!-- メインコピー -->
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-5">
          VB6・レガシーシステムを、<br class="hidden sm:block" />
          <span class="text-accent-400">次世代SaaS</span>へ。<br />
          AI支援で確実に。
        </h1>

        <p class="text-base sm:text-lg text-primary-200 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          製造業の生産管理システムをVB6から<strong class="text-white">クラウドWebシステム</strong>へ。
          160機能・15業務ドメインを、既存MySQLデータそのままで移行。
          業務を止めずに並行運用で安全に切り替えます。
        </p>

        <!-- CTAボタン -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start mb-8">
          <a
            href={url('/demo/')}
            class="inline-flex items-center justify-center px-6 py-3.5 rounded-xl bg-accent-500 text-white font-bold text-base hover:bg-accent-600 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.847v6.306a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            無料デモを申し込む
          </a>
          <a
            href={url('/features/')}
            class="inline-flex items-center justify-center px-6 py-3.5 rounded-xl border-2 border-primary-600 text-primary-200 font-semibold text-base hover:bg-primary-800 hover:border-primary-500 hover:text-white transition-all"
          >
            機能を見る
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- 信頼バッジ -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 text-sm text-primary-300">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>導入15社以上</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>最短3ヶ月で移行</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>既存DBそのまま</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>IT経営力大賞受賞</span>
          </div>
        </div>
      </div>

      <!-- ダッシュボード画像 -->
      <div class="flex-1 w-full max-w-2xl animate-fade-in-up animation-delay-200">
        <div class="relative">
          <!-- ブラウザ風フレーム -->
          <div class="bg-slate-700 rounded-t-xl px-4 py-3 flex items-center gap-2">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
            </div>
            <div class="flex-1 bg-slate-600 rounded-md px-3 py-1 text-xs text-slate-400">
              app.pt-saas.jp/dashboard
            </div>
          </div>
          <img
            src={url('/images/screenshots/dashboard-new.png')}
            alt="PT-SaaSダッシュボード画面"
            class="w-full rounded-b-xl shadow-2xl"
            loading="eager"
          />
          <!-- グロー効果 -->
          <div class="absolute -inset-4 bg-primary-500/10 rounded-2xl blur-2xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 波形区切り -->
  <div class="text-slate-50">
    <svg viewBox="0 0 1440 60" fill="currentColor" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-10 sm:h-14">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" />
    </svg>
  </div>
</section>
