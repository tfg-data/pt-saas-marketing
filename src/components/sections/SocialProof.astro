---
const stats = [
  { value: '15社以上', label: '導入企業数' },
  { value: '2007年', label: '稼働開始' },
  { value: '3段階', label: '段階的導入' },
  { value: '24時間', label: 'サポート対応' },
];
---

<section class="py-16 bg-white border-y border-slate-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 受賞実績 -->
    <div class="bg-gradient-to-r from-primary-600 to-primary-700 rounded-2xl p-8 sm:p-10 mb-14 text-white text-center">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-white/20 mb-4">
        <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      </div>
      <h2 class="text-2xl sm:text-3xl font-bold mb-2">IT経営力大賞2009</h2>
      <p class="text-xl font-semibold text-primary-100 mb-3">経済産業大臣賞・最優秀賞 受賞</p>
      <p class="text-sm text-primary-200 max-w-xl mx-auto leading-relaxed">
        2007年に田中精工株式会社が自社・協力工場10社の生産管理を可視化するために開発。
        工程進捗・不良情報をリアルタイムに共有し、経営課題を解決した取り組みが高く評価されました。
      </p>
    </div>

    <!-- 数値実績 -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-black text-primary-600 mb-1">{stat.value}</div>
          <div class="text-sm text-slate-500 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
