---
const testimonials = [
  {
    text: 'VB6の保守担当が退職し困っていましたが、PT-SaaSへの移行でTypeScriptになり社内誰でもメンテナンスできるようになりました。',
    company: '愛知県・自動車部品メーカー',
    size: '従業員50名',
    role: '情報システム担当',
  },
  {
    text: '3ヶ月の並行運用期間で現場スタッフが慣れることができ、スムーズに切り替えできました。Excelとの二重入力もなくなり業務が大幅に効率化されました。',
    company: '大阪府・樹脂加工メーカー',
    size: '従業員30名',
    role: '製造部長',
  },
  {
    text: 'Crystal Reportsのライセンス問題で毎年悩んでいましたが、React-PDFへの移行で帳票がWebで完結するようになり助かっています。',
    company: '愛知県・金属加工メーカー',
    size: '従業員80名',
    role: 'システム管理者',
  },
];
---

<section class="bg-primary-50 py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block bg-primary-100 text-primary-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4">
        導入事例
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">導入企業の声</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {testimonials.map((t) => (
        <div class="bg-white rounded-2xl p-6 border border-primary-100 shadow-sm hover:shadow-md transition-shadow">
          <!-- 引用符 -->
          <div class="text-4xl text-primary-200 font-serif leading-none mb-3">"</div>
          <p class="text-slate-700 text-sm leading-relaxed mb-5">{t.text}</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-slate-900">{t.role}</p>
            <p class="text-xs text-slate-500">{t.company}</p>
            <p class="text-xs text-slate-400">{t.size}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
