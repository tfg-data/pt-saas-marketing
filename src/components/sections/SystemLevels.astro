---
const levels = [
  {
    id: 'level1',
    label: 'Level 1',
    title: '受注・出荷・売上',
    subtitle: '部材支給の小規模製造業に最適',
    color: 'primary',
    modules: [
      { group: '受注', items: ['EDIデータ受信・自動登録', '受注伝票入力', '受注残集計'] },
      { group: '出荷', items: ['ピッキングリスト', '出荷入力・確定', '検品・製品タグ印刷'] },
      { group: '売上', items: ['得意先別売上', '納品書作成', '請求書作成'] },
    ],
    screenshot: '/images/screenshots/orders.png',
  },
  {
    id: 'level2',
    label: 'Level 2',
    title: '購買・外注・支払',
    subtitle: '自社で部材を調達する企業に',
    color: 'accent',
    modules: [
      { group: '外注管理', items: ['外注受入管理', '部品注文書', '外注注残検索'] },
      { group: '購買管理', items: ['購買伝票入力', '購買検収確定・取消', '購入明細'] },
      { group: '支払管理', items: ['支払管理', '支払内訳', '購買外注仮検収'] },
    ],
    screenshot: '/images/screenshots/shipping.png',
  },
  {
    id: 'level3',
    label: 'Level 3',
    title: '生産計画・工程・在庫',
    subtitle: '本格的な生産管理を実現',
    color: 'green',
    modules: [
      { group: '生産計画', items: ['生産計画入力・推移表', '指図書採番（所要量展開）', '指図書発行・印刷'] },
      { group: '工程管理', items: ['作業報告入力', '工程進捗管理', 'ロットトレース'] },
      { group: '在庫管理', items: ['入出庫処理', '棚卸管理', '製品未出庫リスト'] },
    ],
    screenshot: '/images/screenshots/production.png',
  },
];

const colorMap = {
  primary: { badge: 'bg-primary-100 text-primary-700', dot: 'bg-primary-500', border: 'border-primary-200' },
  accent: { badge: 'bg-accent-100 text-accent-700', dot: 'bg-accent-500', border: 'border-accent-200' },
  green: { badge: 'bg-green-100 text-green-700', dot: 'bg-green-500', border: 'border-green-200' },
};
---

<section class="py-20 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
        3段階で段階的に導入
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Level 1から始めて、事業拡大に合わせてLevel 3まで拡張できます。<br class="hidden sm:block" />
        無駄なく、必要な機能だけ利用できます。
      </p>
    </div>

    <!-- 積み上げ図 -->
    <div class="flex flex-col items-center gap-1 mb-12 max-w-lg mx-auto">
      {[...levels].reverse().map((level, i) => {
        const c = colorMap[level.color as keyof typeof colorMap];
        const widths = ['w-full', 'w-10/12', 'w-8/12'];
        return (
          <a
            href={`/features/#${level.id}`}
            class:list={[
              'block px-6 py-3 rounded-lg text-center font-semibold text-sm transition-all hover:scale-105',
              widths[i],
              c.badge,
              'border-2',
              c.border,
            ]}
          >
            {level.label} — {level.title}
          </a>
        );
      })}
    </div>

    <!-- レベルカード -->
    <div class="space-y-10">
      {levels.map((level) => {
        const c = colorMap[level.color as keyof typeof colorMap];
        return (
          <div id={level.id} class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
            <div class="grid lg:grid-cols-2">
              <!-- テキスト -->
              <div class="p-8">
                <div class:list={['inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold mb-4', c.badge]}>
                  <span class:list={['w-2 h-2 rounded-full', c.dot]}></span>
                  {level.label}
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-1">{level.title}</h3>
                <p class="text-sm text-slate-500 mb-6">{level.subtitle}</p>

                <div class="grid sm:grid-cols-3 gap-4">
                  {level.modules.map((mod) => (
                    <div>
                      <h4 class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-2">{mod.group}</h4>
                      <ul class="space-y-1.5">
                        {mod.items.map((item) => (
                          <li class="flex items-start gap-1.5 text-xs text-slate-700">
                            <span class:list={['mt-1 w-1.5 h-1.5 rounded-full flex-shrink-0', c.dot]}></span>
                            {item}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>

                <a
                  href={`/features/#${level.id}`}
                  class="inline-flex items-center gap-1.5 mt-6 text-sm font-semibold text-primary-600 hover:text-primary-700"
                >
                  詳細を見る
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>

              <!-- スクリーンショット -->
              <div class="relative bg-slate-800 flex items-center justify-center min-h-48 lg:min-h-0 overflow-hidden">
                <img
                  src={level.screenshot}
                  alt={`${level.title}画面`}
                  class="w-full h-full object-cover object-top opacity-90"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                />
                <div class="hidden absolute inset-0 flex-col items-center justify-center text-white opacity-30 gap-2">
                  <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span class="text-xs">スクリーンショット準備中</span>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
