---
const screenshots = [
  {
    src: '/images/screenshots/dashboard-new.png',
    alt: 'PT-SaaSダッシュボード — KPIカード・売上推移チャート',
    caption: 'ダッシュボード',
    desc: 'リアルタイムKPI・売上推移・得意先別構成をひと目で確認'
  },
  {
    src: '/images/screenshots/orders-new.png',
    alt: '受注管理一覧 — 検索パネル・データテーブル',
    caption: '受注管理',
    desc: 'キーワード・日付・状態で絞り込み。ソート・ページング対応'
  },
  {
    src: '/images/screenshots/shipping-new.png',
    alt: '出荷管理 — 出荷伝票一覧',
    caption: '出荷管理',
    desc: '出荷伝票の登録・変更・削除。納品書印刷まで一画面で完結'
  },
  {
    src: '/images/screenshots/customer-master-new.png',
    alt: '得意先マスタ — オムロン・デンソー等の取引先を管理',
    caption: '得意先マスタ',
    desc: 'オムロン・デンソー・トヨタ等、大手取引先の管理実績'
  },
];
---

<section class="bg-white py-16 sm:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block bg-slate-100 text-slate-600 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4">
        実際の画面
      </span>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">
        モダンなUIで、業務をシンプルに
      </h2>
      <p class="text-slate-600">
        VB6と同じ業務ロジックを、現代的なWebUIで再現。スマートフォン・タブレットでも操作できます。
      </p>
    </div>

    <!-- スクリーンショットグリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {screenshots.map((ss) => (
        <div class="group rounded-2xl overflow-hidden border border-slate-200 hover:shadow-xl transition-shadow">
          <div class="bg-slate-100 px-4 py-2.5 flex items-center gap-2 border-b border-slate-200">
            <div class="flex gap-1">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
            </div>
            <span class="text-xs text-slate-500 font-medium">{ss.caption}</span>
          </div>
          <img
            src={ss.src}
            alt={ss.alt}
            class="w-full object-cover group-hover:scale-[1.01] transition-transform duration-300"
            loading="lazy"
          />
          <div class="p-4 bg-slate-50">
            <p class="text-sm font-semibold text-slate-800">{ss.caption}</p>
            <p class="text-xs text-slate-500 mt-0.5">{ss.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
